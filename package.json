{
  "name": "keep-up",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "tsc --project tsconfig.test.json && node --test .test-dist/tests/domain-behavior.test.js .test-dist/tests/persistence.test.js .test-dist/tests/application-services.test.js .test-dist/tests/season-setup-workflow.test.js .test-dist/tests/guided-setup-workflow.test.js .test-dist/tests/season-review-workflow.test.js .test-dist/tests/assistant-boundaries.test.js .test-dist/tests/postgres-integration.test.js .test-dist/tests/authentication.test.js .test-dist/tests/ownership-isolation.test.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:check": "drizzle-kit check",
    "db:studio": "drizzle-kit studio",
    "test:db": "tsc --project tsconfig.test.json && node --test .test-dist/tests/postgres-integration.test.js",
    "test:postgres": "tsc --project tsconfig.test.json && node --test .test-dist/tests/postgres-real.test.js",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report playwright-report"
  },
  "dependencies": {
    "better-auth": "^1.6.23",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.10",
    "pg": "^8.22.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@next/env": "^16.2.10",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
